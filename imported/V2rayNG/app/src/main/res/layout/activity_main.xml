<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neon_bg_dark">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/neon_bg_dark"
        android:fitsSystemWindows="true">

        <!-- Background blobs -->
        <View
            android:layout_width="500dp"
            android:layout_height="500dp"
            android:layout_gravity="top|start"
            android:layout_marginStart="-80dp"
            android:layout_marginTop="-80dp"
            android:background="@drawable/bg_blob_accent"
            android:alpha="0.15" />

        <View
            android:layout_width="400dp"
            android:layout_height="400dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="-60dp"
            android:layout_marginBottom="-60dp"
            android:background="@drawable/bg_blob_success"
            android:alpha="0.12" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fillViewport="true"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/neon_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="@drawable/bg_card_main"
                android:clipToOutline="true"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="24dp"
                android:elevation="8dp">

                <!-- SCANLINE overlay -->
                <View
                    android:id="@+id/scanline_overlay"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_scanlines"
                    android:clickable="false"
                    android:focusable="false"
                    android:importantForAccessibility="no"
                    android:alpha="0.15" />

                <!-- HEADER: Shield + Mir2Ray + badge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_shield_icon">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_shield_24dp"
                            android:tint="@color/neon_circle_glow_blue" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tv_brand_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="@string/neon_brand_title"
                        android:textColor="#E5E5E5"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_config_count_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_config_badge"
                        android:paddingStart="12dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp"
                        android:text="Configs: 0"
                        android:textColor="#D1D5DB"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- CIRCLE CONNECT BUTTON -->
                <FrameLayout
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="8dp">

                    <View
                        android:id="@+id/ring_connected"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_ring_connected"
                        android:visibility="gone" />

                    <ProgressBar
                        android:id="@+id/pb_connecting_ring"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:indeterminate="true"
                        android:indeterminateTint="@color/neon_circle_glow_blue"
                        android:visibility="gone" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_connect"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_circle_connect"
                        android:gravity="center"
                        android:text="@string/neon_connect"
                        android:textAllCaps="false"
                        android:textColor="#D1D5DB"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:cornerRadius="80dp"
                        app:strokeWidth="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />

                    <ImageView
                        android:id="@+id/iv_power_icon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:layout_marginTop="-20dp"
                        android:src="@drawable/ic_power_24dp"
                        android:tint="#D1D5DB"
                        android:clickable="false"
                        android:focusable="false" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tv_connection_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    android:gravity="center"
                    android:text="@string/neon_disconnected"
                    android:textColor="#9CA3AF"
                    android:textSize="13sp" />

                <ProgressBar
                    android:id="@+id/pb_connect"
                    style="?android:attr/progressBarStyle"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginBottom="8dp"
                    android:indeterminateTint="#3b82f6"
                    android:visibility="gone" />

                <!-- LIVE STATS PANEL -->
                <LinearLayout
                    android:id="@+id/layout_live_stats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_live_panel"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">
                                <ImageView
                                    android:layout_width="12dp"
                                    android:layout_height="12dp"
                                    android:src="@drawable/ic_globe_24dp"
                                    android:tint="#6B7280" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="4dp"
                                    android:text="IP"
                                    android:textColor="#6B7280"
                                    android:textSize="11sp" />
                            </LinearLayout>
                            <TextView
                                android:id="@+id/tv_live_ip"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="---"
                                android:textIsSelectable="true"
                                android:textColor="#39FF14"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Active DNS"
                                android:textColor="#6B7280"
                                android:textSize="11sp" />
                            <TextView
                                android:id="@+id/tv_live_dns"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="---"
                                android:textColor="#39FF14"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_speed_row"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:padding="10dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_download_24dp"
                            android:tint="#10b981" />
                        <TextView
                            android:id="@+id/tv_dl_speed"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:fontFamily="monospace"
                            android:text="0 KB/s"
                            android:textColor="#DDDDDD"
                            android:textSize="13sp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_upload_24dp"
                            android:tint="#3b82f6" />
                        <TextView
                            android:id="@+id/tv_ul_speed"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:fontFamily="monospace"
                            android:gravity="end"
                            android:text="0 KB/s"
                            android:textColor="#DDDDDD"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 2x2 ACTION GRID - Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_give_configs"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="match_parent"
                            android:layout_height="108dp"
                            android:text="@string/neon_give_new_configs"
                            android:textAllCaps="false"
                            android:textColor="#E5E5E5"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="start|bottom"
                            android:padding="14dp"
                            app:backgroundTint="@color/neon_button_bg"
                            app:cornerRadius="16dp"
                            app:strokeColor="#2a2a2a"
                            app:strokeWidth="1dp"
                            app:icon="@drawable/ic_download_24dp"
                            app:iconGravity="textStart"
                            app:iconTint="#60a5fa"
                            app:iconSize="18dp" />

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/pb_give_progress"
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:layout_marginTop="-4dp"
                            android:max="100"
                            android:visibility="gone"
                            app:indicatorColor="#3b82f6"
                            app:trackColor="@android:color/transparent" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_optimize"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="match_parent"
                            android:layout_height="108dp"
                            android:text="@string/neon_optimize"
                            android:textAllCaps="false"
                            android:textColor="#E5E5E5"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="start|bottom"
                            android:padding="14dp"
                            app:backgroundTint="@color/neon_button_bg"
                            app:cornerRadius="16dp"
                            app:strokeColor="#2a2a2a"
                            app:strokeWidth="1dp"
                            app:icon="@drawable/ic_flash_24dp"
                            app:iconGravity="textStart"
                            app:iconTint="#34d399"
                            app:iconSize="18dp" />

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/pb_optimize_progress"
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:layout_marginTop="-4dp"
                            android:max="100"
                            android:visibility="gone"
                            app:indicatorColor="#10b981"
                            app:trackColor="@android:color/transparent" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 2x2 ACTION GRID - Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_import"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:text="Import"
                        android:textAllCaps="false"
                        android:textColor="#D1D5DB"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/neon_button_bg"
                        app:cornerRadius="12dp"
                        app:strokeColor="#2a2a2a"
                        app:strokeWidth="1dp"
                        app:icon="@drawable/ic_add_24dp"
                        app:iconGravity="textStart"
                        app:iconTint="#9CA3AF"
                        app:iconSize="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_test_dns"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:text="Test DNS"
                        android:textAllCaps="false"
                        android:textColor="#D1D5DB"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/neon_button_bg"
                        app:cornerRadius="12dp"
                        app:strokeColor="#2a2a2a"
                        app:strokeWidth="1dp"
                        app:icon="@drawable/ic_activity_24dp"
                        app:iconGravity="textStart"
                        app:iconTint="#9CA3AF"
                        app:iconSize="16dp" />
                </LinearLayout>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/pb_dns_progress"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="2dp"
                    android:max="100"
                    android:visibility="gone"
                    app:indicatorColor="#39FF14"
                    app:trackColor="@android:color/transparent" />

                <!-- NEXT CONFIG -->
                <LinearLayout
                    android:id="@+id/layout_next_config"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_row_button"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:visibility="gone"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_skip_24dp"
                        android:tint="#9CA3AF" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="@string/neon_next_config"
                        android:textColor="#E5E5E5"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_chevron_right"
                        android:tint="#6B7280" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_process_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:text="@string/neon_idle"
                    android:textColor="#39FF14"
                    android:textSize="12sp" />
            </LinearLayout>
        </ScrollView>

                <com.google.android.material.appbar.AppBarLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone">
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize" />
        </com.google.android.material.appbar.AppBarLayout>

        <!-- Hidden stubs for code compatibility -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:orientation="vertical">

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/pb_waiting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                app:indicatorColor="@color/neon_green" />

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view"
                android:layout_width="match_parent"
                android:layout_height="0dp" />

            <LinearLayout
                android:id="@+id/layout_test"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_test_state"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/connection_test_pending" />
            </LinearLayout>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_play_24dp" />
        </LinearLayout>
    </FrameLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:visibility="gone"
        app:headerLayout="@layout/nav_header"
        app:itemIconTint="@color/colorAccent"
        app:menu="@menu/menu_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>
