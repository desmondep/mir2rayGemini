<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neon_bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:orientation="vertical">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize" />

        </com.google.android.material.appbar.AppBarLayout>

        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:id="@+id/main_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/neon_bg_dark">

            <LinearLayout
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/pb_waiting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    android:visibility="invisible"
                    app:indicatorColor="@color/neon_green" />

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tab_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <LinearLayout
                    android:id="@+id/layout_test"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_test_state"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/connection_test_pending" />
                </LinearLayout>

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fab"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_play_24dp" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:foregroundGravity="center">

                <LinearLayout
                    android:id="@+id/neon_container"
                    android:layout_width="360dp"
                    android:layout_height="720dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_neon_panel"
                    android:clipToOutline="true"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <View
                        android:id="@+id/scanline_overlay"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_scanlines"
                        android:clickable="false"
                        android:focusable="false"
                        android:importantForAccessibility="no"
                        android:alpha="0.22" />

                    <TextView
                        android:id="@+id/tv_brand_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:gravity="center"
                        android:text="@string/neon_brand_title"
                        android:textColor="@color/neon_green"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_connection_state"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:gravity="center"
                        android:text="@string/neon_disconnected"
                        android:textColor="@color/neon_green"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <!-- Live Stats Area (Initially Hidden) -->
                    <LinearLayout
                        android:id="@+id/layout_live_stats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_bottom_sheet"
                        android:backgroundTint="#101A10"
                        android:padding="12dp"
                        android:visibility="gone">
                        
                        <!-- IP & DNS row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Live IP"
                                    android:textSize="12sp"
                                    android:textColor="#888888" />
                                <TextView
                                    android:id="@+id/tv_live_ip"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="---"
                                    android:textIsSelectable="true"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/neon_green" />
                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="end">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Active DNS"
                                    android:textSize="12sp"
                                    android:textColor="#888888" />
                                <TextView
                                    android:id="@+id/tv_live_dns"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="---"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/neon_green" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Speed row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:background="#202A20"
                            android:padding="8dp"
                            android:gravity="center">
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="↓"
                                android:textColor="#00FF00"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginEnd="4dp" />
                            <TextView
                                android:id="@+id/tv_dl_speed"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="0 KB/s"
                                android:textColor="#DDDDDD"
                                android:textSize="14sp"
                                android:fontFamily="monospace" />
                                
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="↑"
                                android:textColor="#00AAFF"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginEnd="4dp" />
                            <TextView
                                android:id="@+id/tv_ul_speed"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="0 KB/s"
                                android:textColor="#DDDDDD"
                                android:textSize="14sp"
                                android:gravity="end"
                                android:fontFamily="monospace" />
                        </LinearLayout>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_give_configs"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="12dp"
                        android:text="@string/neon_give_new_configs"
                        android:textAllCaps="false"
                        android:textColor="@color/neon_green"
                        app:backgroundTint="@color/neon_button_bg"
                        app:strokeColor="@color/neon_green"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/pb_give_progress"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginTop="-8dp"
                        android:layout_marginBottom="12dp"
                        android:max="100"
                        android:visibility="gone"
                        app:indicatorColor="@color/neon_green"
                        app:trackColor="@color/neon_button_bg" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_optimize"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="12dp"
                        android:text="@string/neon_optimize"
                        android:textAllCaps="false"
                        android:textColor="@color/neon_green"
                        app:backgroundTint="@color/neon_button_bg"
                        app:strokeColor="@color/neon_green"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/pb_optimize_progress"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginTop="-8dp"
                        android:layout_marginBottom="12dp"
                        android:max="100"
                        android:visibility="gone"
                        app:indicatorColor="@color/neon_green"
                        app:trackColor="@color/neon_button_bg" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_test_dns"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="12dp"
                        android:text="تست و تنظیم بهترین DNS"
                        android:textAllCaps="false"
                        android:textColor="@color/neon_green"
                        app:backgroundTint="@color/neon_button_bg"
                        app:strokeColor="@color/neon_green"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/pb_dns_progress"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginTop="-8dp"
                        android:layout_marginBottom="12dp"
                        android:max="100"
                        android:visibility="gone"
                        app:indicatorColor="@color/neon_green"
                        app:trackColor="@color/neon_button_bg" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_connect"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="@string/neon_connect"
                        android:textAllCaps="false"
                        android:textColor="@color/neon_green"
                        app:backgroundTint="@color/neon_button_bg"
                        app:strokeColor="@color/neon_green"
                        app:strokeWidth="1dp" />

                    <ProgressBar
                        android:id="@+id/pb_connect"
                        style="?android:attr/progressBarStyle"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginTop="14dp"
                        android:indeterminateTint="@color/neon_green"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_process_state"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:text="@string/neon_idle"
                        android:textColor="@color/neon_green"
                        android:textSize="14sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_next_config"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="14dp"
                        android:text="@string/neon_next_config"
                        android:textAllCaps="false"
                        android:textColor="@color/neon_green"
                        android:textSize="13sp"
                        android:visibility="gone"
                        app:strokeColor="@color/neon_green"
                        app:strokeWidth="1dp" />

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />
                </LinearLayout>
            </FrameLayout>

            <TextView
                android:id="@+id/tv_config_count_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_neon_panel"
                android:elevation="8dp"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:text="Configs: 0"
                android:textColor="@color/neon_green"
                android:textSize="12sp"
                android:textStyle="bold" />
        </androidx.coordinatorlayout.widget.CoordinatorLayout>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:visibility="gone"
        app:headerLayout="@layout/nav_header"
        app:itemIconTint="@color/colorAccent"
        app:menu="@menu/menu_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>
